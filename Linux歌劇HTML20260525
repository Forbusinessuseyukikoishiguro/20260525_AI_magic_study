 return `あなたは「Linux 歌劇」（歌劇の語り口）の教材作家です。Linux初学者向けに1場。お題：「${topic}」。次のJSONだけ返す（前置き禁止）。\n{"act":"第◯幕","title":"タイトル","lead":"歌劇らしい語り口で2〜3文。改行は \\n。HTMLタグ禁止","bullets":["リブレット3〜5個。空配列可"],"cmd":"コマンド例。#で注釈可。無ければ空文字","one":"締めの一言","who":"プロンプターの一言"}`;}
function mkQuiz(q){let choices=Array.isArray(q.choices)?q.choices.filter(c=>String(c).trim()).map(c=>String(c).trim()):[];if(choices.length<2)throw new Error("選択肢を生成できませんでした");let ans=Number(q.answer);if(!Number.isInteger(ans)||ans<0||ans>=choices.length)ans=0;
