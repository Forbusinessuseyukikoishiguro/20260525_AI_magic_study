/* ---------- dust motes ---------- */
const cv=$("#dust"),cx2=cv.getContext('2d');let W,H,P;
function size(){W=cv.width=innerWidth;H=cv.height=innerHeight;}size();addEventListener('resize',size);
function spawn(){return{x:Math.random()*W,y:H+Math.random()*H,r:Math.random()*2.2+.5,s:Math.random()*.5+.15,a:Math.random()*.55+.2,tw:Math.random()*6.28,gold:Math.random()>.45};}
P=Array.from({length:70},spawn);
function loop(){cx2.clearRect(0,0,W,H);for(const p of P){p.y-=p.s;p.x+=Math.sin(p.tw)*.3;p.tw+=.02;
 if(p.y<-10)Object.assign(p,spawn(),{y:H+10});const fl=p.a*(.6+.4*Math.sin(p.tw*3));const col=p.gold?"255,205,100":"255,120,80";
 const g=cx2.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*4);g.addColorStop(0,`rgba(${col},${fl})`);g.addColorStop(.5,`rgba(${col},${fl*.4})`);g.addColorStop(1,`rgba(${col},0)`);
 cx2.fillStyle=g;cx2.beginPath();cx2.arc(p.x,p.y,p.r*4,0,7);cx2.fill();}requestAnimationFrame(loop);}loop();

