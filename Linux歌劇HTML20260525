function buildPrompt(topic,kind){
 if(kind==="lesson")return `あなたは「Linux 歌劇」という、華やかな歌劇（オペラ）の語り口の教材作家です。お題について、Linux初学者向けに「1つの幕」を作成。本編1場＋アリア（3択）1問。\nお題：「${topic}」\n次のJSONだけ返す（前置き・コードフェンス禁止）。\n{"act":"第◯幕","title":"本編タイトル","lead":"歌劇らしい語り口で2〜3文。改行は \\n。HTMLタグ禁止","bullets":["リブレット3〜5個。各15〜30字。空配列可"],"cmd":"コマンド例。1〜3行。#で注釈可。無ければ空文字","one":"締めの一言","who":"プロンプターのやさしい一言","quiz":{"title":"アリア","question":"設問1文","choices":["A","B","C"],"answer":0,"explain":"正解理由を1〜2文","who":"ヒント一言"}}`;
