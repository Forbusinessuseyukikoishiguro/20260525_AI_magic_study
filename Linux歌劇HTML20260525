function downloadBlob(blob,name){const u=URL.createObjectURL(blob);const a=document.createElement('a');a.href=u;a.download=name;document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(u),2000);}
function stamp(){const d=new Date();const p=n=>String(n).padStart(2,'0');return `${d.getFullYear()}${p(d.getMonth()+1)}${p(d.getDate())}`;}
async function buildCertCanvas(){try{if(document.fonts&&document.fonts.ready)await document.fonts.ready;}catch(e){}
 const W=1684,H=1190,cv=document.createElement('canvas');cv.width=W;cv.height=H;const g=cv.getContext('2d');
 const C={ink:"#2c1810",ink2:"#4a2c18",gold:"#d4af37",goldD:"#a8821f",velvet:"#7a0f1c",green:"#2e7d52"};
 const bg=g.createLinearGradient(0,0,0,H);bg.addColorStop(0,"#fffaf0");bg.addColorStop(1,"#ecdab2");g.fillStyle=bg;g.fillRect(0,0,W,H);
 g.strokeStyle=C.goldD;g.lineWidth=10;g.strokeRect(46,46,W-92,H-92);g.lineWidth=2;g.strokeStyle=C.gold;g.strokeRect(66,66,W-132,H-132);
 const cx=W/2;g.textAlign="center";
 g.fillStyle=C.velvet;g.font='30px "Cinzel",serif';g.fillText("P R O G R A M M E   D ' H O N N E U R",cx,180);
 g.fillStyle=C.ink;g.font='900 104px "Playfair Display","Shippori Mincho",serif';g.fillText("修 了 証",cx,308);
 const gr=g.createLinearGradient(cx-190,0,cx+190,0);gr.addColorStop(0,"rgba(168,130,31,0)");gr.addColorStop(.5,C.goldD);gr.addColorStop(1,"rgba(168,130,31,0)");g.fillStyle=gr;g.fillRect(cx-190,346,380,3);
 const name=(learnerName||"").trim()||"貴方";
 g.fillStyle=C.ink;g.font='600 30px "Shippori Mincho",serif';g.fillText("次の歌い手に、これを授与する",cx,418);
 g.fillStyle=C.velvet;g.font='800 76px "Shippori Mincho",serif';g.fillText(name+"　殿",cx,506);
 g.strokeStyle="rgba(122,15,28,.4)";g.lineWidth=2;g.beginPath();g.moveTo(cx-360,528);g.lineTo(cx+360,528);g.stroke();
 g.fillStyle=C.ink2;g.font='500 30px "Shippori Mincho",serif';g.fillText("Linux 歌劇 の全幕を踏破し、黒き舞台のアリアを謳い修めり。",cx,582);
 const {total,answered,correct}=stats();const [rk]=rankOf(total?correct/total:0);
 if(total){g.fillStyle=C.ink;g.font='800 46px "Shippori Mincho",serif';g.fillText(`名演 ${correct} / ${total} 曲`+(answered<total?`　（未挑戦 ${total-answered}）`:""),cx,660);
   g.fillStyle=C.goldD;g.font='italic 38px "Cormorant Garamond",serif';g.fillText("称号 ── "+rk,cx,714);}
 const bd=breakdown();if(bd.length){const sY=768,rh=40,cw=560,half=Math.ceil(bd.length/2);g.font='500 24px "Shippori Mincho",serif';g.textAlign="left";
  bd.forEach((b,i)=>{const col=i<half?0:1,row=i<half?i:i-half,x=cx-cw+col*cw,y=sY+row*rh;
   g.fillStyle=C.ink2;g.fillText(`${b.act}　${b.title}`.slice(0,22),x,y);
   g.fillStyle=b.state==="ok"?C.green:(b.state==="miss"?C.velvet:"#9a7b4a");g.font='700 26px "Shippori Mincho",serif';
   g.fillText(b.state==="ok"?"◯":(b.state==="miss"?"✕":"—"),x+cw-60,y);g.font='500 24px "Shippori Mincho",serif';});g.textAlign="center";}
 const d=new Date();g.fillStyle=C.ink2;g.font='italic 30px "Cormorant Garamond",serif';g.fillText(`${d.getFullYear()}年 ${d.getMonth()+1}月 ${d.getDate()}日　—　L'Opéra du Terminal`,cx,H-150);
 g.beginPath();g.arc(W-250,H-205,66,0,7);g.fillStyle=C.velvet;g.fill();g.lineWidth=3;g.strokeStyle=C.goldD;g.stroke();g.font='40px serif';g.fillStyle="#fff";g.fillText("🎭",W-250,H-190);
 return cv;}
function dataURLToBytes(durl){const b=atob(durl.split(",")[1]);const u=new Uint8Array(b.length);for(let i=0;i<b.length;i++)u[i]=b.charCodeAt(i);return u;}
function buildJpegPDF(jpeg,iw,ih){const PW=842,PH=595;const enc=s=>new TextEncoder().encode(s);
 const parts=[];let len=0;const off=[];const push=u=>{parts.push(u);len+=u.length;};
 push(enc("%PDF-1.4\n%\xE2\xE3\xCF\xD3\n"));const obj=(n,b)=>{off[n]=len;push(enc(n+" 0 obj\n"+b+"\nendobj\n"));};
 obj(1,"<< /Type /Catalog /Pages 2 0 R >>");obj(2,"<< /Type /Pages /Kids [3 0 R] /Count 1 >>");
 obj(3,`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${PW} ${PH}] /Resources << /XObject << /Im0 5 0 R >> >> /Contents 4 0 R >>`);
 const ct=`q ${PW} 0 0 ${PH} 0 0 cm /Im0 Do Q`;obj(4,`<< /Length ${ct.length} >>\nstream\n${ct}\nendstream`);
 off[5]=len;push(enc(`5 0 obj\n<< /Type /XObject /Subtype /Image /Width ${iw} /Height ${ih} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${jpeg.length} >>\nstream\n`));
 push(jpeg);push(enc("\nendstream\nendobj\n"));const xp=len;let x="xref\n0 6\n0000000000 65535 f \n";
 for(let i=1;i<=5;i++)x+=String(off[i]).padStart(10,"0")+" 00000 n \n";push(enc(x));push(enc(`trailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n${xp}\n%%EOF`));
 const out=new Uint8Array(len);let o=0;for(const p of parts){out.set(p,o);o+=p.length;}return out;}
async function exportCert(kind){const cvv=await buildCertCanvas();
 if(kind==="png"){cvv.toBlob(b=>{if(b)downloadBlob(b,`Opera_Terminal_Certificate_${stamp()}.png`);},"image/png");}
 else{const jpeg=dataURLToBytes(cvv.toDataURL("image/jpeg",0.92));downloadBlob(new Blob([buildJpegPDF(jpeg,cvv.width,cvv.height)],{type:"application/pdf"}),`Opera_Terminal_Certificate_${stamp()}.pdf`);}}
async function exportCertificatePDF(){await exportCert("pdf");}

/* ====================== EDITOR ====================== */
const panel=$("#panel"),dim=$("#dim");
function openEd(){panel.classList.add('show');dim.classList.add('show');renderList();}
function closeEd(){panel.classList.remove('show');dim.classList.remove('show');}
$("#openEditor")&&($("#openEditor").onclick=openEd);
$("#closeEditor")&&($("#closeEditor").onclick=closeEd);dim.onclick=closeEd;
$("#f-type").onchange=()=>{const t=$("#f-type").value;document.querySelectorAll('[data-only]').forEach(el=>el.classList.toggle('hidden',!el.dataset.only.split(' ').includes(t)));};
$("#f-provider").onchange=()=>$("#openaiCfg").classList.toggle('hidden',$("#f-provider").value!=="openai");
function flash(k,t){const m=$("#aiMsg");m.className="msg "+k;m.textContent=t;setTimeout(()=>{m.className="msg";},4500);}
function renderList(){const L=$("#sceneList");L.innerHTML="";
 deck.forEach((s,i)=>{const name=s.titleGrand||s.title||s.question||(s.type==="certificate"?"修了証（自動）":"（無題）");
  const row=document.createElement('div');row.className='scene-row'+(i===idx?' cur':'');
  if(s.type==="certificate"){row.innerHTML=`<span class="nm">${i+1}. ${esc(name)}</span><span style="font-size:.7rem;color:var(--ink-2)">終幕固定</span>`;row.querySelector('.nm').onclick=()=>go(i);L.appendChild(row);return;}
  row.innerHTML=`<span class="nm" title="${esc(name)}">${i+1}. ${s.type==="quiz"?"♪ ":""}${esc(name)}</span><button data-up>▲</button><button data-down>▼</button><button data-edit>✎</button><button data-del>🗑</button>`;
  row.querySelector('.nm').onclick=()=>go(i);
  row.querySelector('[data-up]').onclick=()=>move(i,-1);row.querySelector('[data-down]').onclick=()=>move(i,1);
  row.querySelector('[data-edit]').onclick=()=>loadForm(i);row.querySelector('[data-del]').onclick=()=>del(i);
  L.appendChild(row);});}
function commit(focus){assignIds();ensureCert();if(focus!=null)idx=focus;idx=Math.max(0,Math.min(idx,deck.length-1));buildSeats();paint();if(panel.classList.contains('show'))renderList();}
function move(i,dd){const j=i+dd;if(j<0||j>=deck.length)return;if(deck[i].type==="certificate"||deck[j].type==="certificate")return;[deck[i],deck[j]]=[deck[j],deck[i]];if(idx===i)idx=j;else if(idx===j)idx=i;commit();}
function del(i){if(deck[i].type==="certificate"||deck.length<=2)return;deck.splice(i,1);if(idx>=deck.length)idx=deck.length-1;commit();}
function insertBeforeEnd(arr){let ins=deck.findIndex(s=>s.type==="certificate");if(ins<0)ins=deck.length;deck.splice(ins,0,...arr);commit(ins);}
function clearForm(){editIndex=null;["act","title","lead","bul","cmd","one","q","choices","explain","who"].forEach(k=>{const el=$("#f-"+k);if(el)el.value="";});$("#f-type").value="normal";$("#f-type").onchange();$("#formTitle").textContent="場をつくる";$("#saveScene").textContent="＋ 追加する";}
$("#clearForm").onclick=clearForm;
function loadForm(i){editIndex=i;const s=deck[i];
 $("#f-type").value=s.type==="cover"?"cover":(s.type==="quiz"?"quiz":"normal");$("#f-type").onchange();
 $("#f-act").value=s.act||"";$("#f-title").value=s.titleGrand||s.title||"";
 $("#f-lead").value=(s.lead||"").replace(/<br\s*\/?>/g,"\n").replace(/<[^>]+>/g,"");
 $("#f-bul").value=(s.bullets||[]).map(b=>b.replace(/<[^>]+>/g,"")).join("\n");
 $("#f-cmd").value=s.cmd||"";$("#f-one").value=s.one||"";
 $("#f-q").value=s.question||"";$("#f-choices").value=(s.choices||[]).map((c,k)=>(k===s.answer?"＊ ":"")+c).join("\n");$("#f-explain").value=s.explain||"";
 $("#f-who").value=s.who||"";
 $("#formTitle").textContent="場を編集（"+(i+1)+"）";$("#saveScene").textContent="✔ 更新する";panel.querySelector('.body').scrollTo({top:0,behavior:'smooth'});}
function readForm(){const t=$("#f-type").value;const g=k=>($("#f-"+k).value||"").trim();const s={html:false};
 if(t==="cover"){s.type="cover";s.kicker=g("act")||"L'Opéra du Terminal";s.titleGrand=g("title");if(g("lead"))s.lead=g("lead");s.emoji="🎭";}
 else if(t==="quiz"){s.type="quiz";s.act=g("act")||"";s.kicker="Aria";s.title=g("title")||"アリア";s.question=g("q");
   const lines=$("#f-choices").value.split("\n").map(x=>x.trim()).filter(Boolean);let ans=0;
   const choices=lines.map((l,k)=>{if(/^＊|^\*/.test(l)){ans=k;return l.replace(/^＊\s*|^\*\s*/,"");}return l;});s.choices=choices;s.answer=ans;if(g("explain"))s.explain=g("explain");}
 else{s.act=g("act");s.title=g("title");if(g("lead"))s.lead=g("lead");
