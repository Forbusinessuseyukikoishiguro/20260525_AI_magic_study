/* 合格者の修了証を一括PDF */
function buildJpegPDFMulti(jpegs){const PW=842,PH=595;const enc=s=>new TextEncoder().encode(s);const parts=[];let len=0;const off=[];const push=u=>{parts.push(u);len+=u.length;};
 push(enc("%PDF-1.4\n%\xE2\xE3\xCF\xD3\n"));const N=jpegs.length;const pg=i=>3+i*3,ct=i=>4+i*3,im=i=>5+i*3,tot=2+N*3;const obj=(n,b)=>{off[n]=len;push(enc(n+" 0 obj\n"+b+"\nendobj\n"));};
 obj(1,"<< /Type /Catalog /Pages 2 0 R >>");obj(2,`<< /Type /Pages /Kids [${Array.from({length:N},(_,i)=>pg(i)+" 0 R").join(" ")}] /Count ${N} >>`);
 jpegs.forEach((j,i)=>{obj(pg(i),`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${PW} ${PH}] /Resources << /XObject << /Im0 ${im(i)} 0 R >> >> /Contents ${ct(i)} 0 R >>`);const c=`q ${PW} 0 0 ${PH} 0 0 cm /Im0 Do Q`;obj(ct(i),`<< /Length ${c.length} >>\nstream\n${c}\nendstream`);
   off[im(i)]=len;push(enc(`${im(i)} 0 obj\n<< /Type /XObject /Subtype /Image /Width ${j.iw} /Height ${j.ih} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${j.bytes.length} >>\nstream\n`));push(j.bytes);push(enc("\nendstream\nendobj\n"));});
 const xp=len;let x=`xref\n0 ${tot+1}\n0000000000 65535 f \n`;for(let i=1;i<=tot;i++)x+=String(off[i]||0).padStart(10,"0")+" 00000 n \n";push(enc(x));push(enc(`trailer\n<< /Size ${tot+1} /Root 1 0 R >>\nstartxref\n${xp}\n%%EOF`));
 const out=new Uint8Array(len);let o=0;for(const p of parts){out.set(p,o);o+=p.length;}return out;}
