const NUM=["①","②","③","④","⑤","⑥","⑦"];
const FLOURISH=`<div class="flourish rise"><svg viewBox="0 0 140 16"><path d="M4 8 H52"/><path d="M136 8 H88"/><path d="M64 8 l6 -5 l6 5 l-6 5 Z"/><circle cx="58" cy="8" r="2"/><circle cx="82" cy="8" r="2"/></svg></div>`;
function orbHTML(emoji){return `<div class="orb rise"><svg viewBox="0 0 200 200">
  <g class="ring"><circle class="sg" cx="100" cy="100" r="92"/><circle class="sgw" cx="100" cy="100" r="92"/>
   <polygon class="sg" points="100,16 175,135 25,135"/><polygon class="sg" points="100,184 25,65 175,65"/></g>
  <g class="ring rev"><circle class="sg" cx="100" cy="100" r="62"/>
   <circle class="sg" cx="100" cy="6" r="4"/><circle class="sg" cx="100" cy="194" r="4"/><circle class="sg" cx="6" cy="100" r="4"/><circle class="sg" cx="194" cy="100" r="4"/></g></svg>
  <div class="glyph">${emoji||"🎭"}</div></div>`;}
function cmdHTML(cmd){if(!cmd)return"";return `<div class="score rise">`+cmd.split("\n").map(line=>{const t=line.trim();if(!t)return"";
  const i=line.indexOf("#");if(i>0){const c=line.slice(0,i).trim(),g=line.slice(i).trim();return `<div><span class="clef">𝄞</span>${esc(c)}  <span class="gloss">${esc(g)}</span></div>`;}
  return `<div><span class="clef">𝄞</span>${esc(t)}</div>`;}).join("")+`</div>`;}

/* ---------- scoring ---------- */
let qidSeq=0;
function assignIds(){deck.forEach(s=>{if(s.type==="quiz"&&!s.qid)s.qid="q"+(++qidSeq);});}
function ensureCert(){const c=deck.find(s=>s.type==="certificate")||{type:"certificate"};deck=deck.filter(s=>s.type!=="certificate");deck.push(c);}
function quizzes(){return deck.filter(s=>s.type==="quiz");}
function stats(){const qs=quizzes();let answered=0,correct=0;qs.forEach(q=>{if(q.qid in results){answered++;if(results[q.qid])correct++;}});return{total:qs.length,answered,correct};}
function breakdown(){return quizzes().map(q=>({act:q.act||"幕",title:q.title||"アリア",state:(q.qid in results)?(results[q.qid]?"ok":"miss"):"none"}));}
function rankOf(r){if(r>=1)return["プリマドンナ","🌹"];if(r>=.8)return["主演歌手","✦"];if(r>=.5)return["合唱団員","♪"];return["研修生","·"];}

/* ---------- bill (page) ---------- */
function billHTML(s){
 if(s.type==="certificate")return certHTML(s);
 if(s.type==="quiz"){
   const opts=(s.choices||[]).map((c,i)=>`<button class="choice" data-i="${i}"><span class="lt">${LETT[i]||i+1}</span><span>${esc(c)}</span></button>`).join("");
   return `<div class="content">
     <div class="kicker rise">${esc(s.kicker||"Aria")}</div>
     <div class="act-label rise">${esc(s.act||"")}</div>
     <h1 class="rise">${esc(s.title||"アリア")}</h1>
     <div class="aria-q rise">${esc(s.question||"")}</div>
     <div class="choices rise">${opts}</div>
     <div class="verdict rise" data-verdict></div>
   </div>
   <div class="prompter"><div class="say">${esc(s.who||"")}</div><div class="who">🎼</div></div>`;
 }
 let c="";
 if(s.type==="cover"){
   c+=`<div class="kicker rise">${esc(s.kicker||"")}</div>`+orbHTML(s.emoji);
   c+=`<h1 class="rise"><span class="title-grand">${s.titleGrand||""}</span></h1>`;
   if(s.subtitle)c+=`<p class="subtitle rise">${esc(s.subtitle)}</p>`;
   if(s.lead!=null)c+=`<p class="lead rise" style="margin-top:1rem;text-align:center">${leadHTML(s)}</p>`;
 }else{
   if(s.kicker)c+=`<div class="kicker rise">${esc(s.kicker)}</div>`;
   if(s.act)c+=`<div class="act-label rise">${esc(s.act)}</div>`;
   c+=`<h1 class="rise">${esc(s.title||"")}</h1>`+FLOURISH;
   if(s.lead!=null)c+=`<p class="lead rise">${leadHTML(s)}</p>`;
   if(s.bullets&&s.bullets.length)c+=`<ul class="libretto rise">`+s.bullets.map((b,i)=>`<li><span class="n">${NUM[i]||(i+1)}</span><span>${s.html?b:nl2br(b)}</span></li>`).join("")+`</ul>`;
   if(s.cmd)c+=cmdHTML(s.cmd);
   if(s.one)c+=`<p class="oneliner rise">${esc(s.one)}</p>`;
 }
 return `<div class="content">${c}</div><div class="prompter"><div class="say">${esc(s.who||"")}</div><div class="who">🎼</div></div>`;
}

/* ---------- certificate ---------- */
function certHTML(s){const {total,answered,correct}=stats();const r=total?correct/total:0;const [title,badge]=rankOf(r);
 const d=new Date();const ymd=`${d.getFullYear()}年 ${d.getMonth()+1}月 ${d.getDate()}日`;
 const mark={ok:"◯",miss:"✕",none:"—"};const bd=breakdown();
 const bdHTML=bd.length?`<div class="cert-break rise">`+bd.map(b=>`<div class="r"><span class="l">${esc(b.act)}</span><span class="t">${esc(b.title)}</span><span style="color:${b.state==='ok'?'#2e7d52':(b.state==='miss'?'var(--velvet)':'#9a7b4a')};font-weight:700">${mark[b.state]}</span></div>`).join("")+`</div>`:"";
 const body= total===0
  ? `<p class="cert-line rise" style="margin-top:.6rem">アリア（確認）に挑むと、ここに成績が刻まれます。</p>`
  : `<div class="cert-score rise">名演 <b>${correct}</b> / ${total} 曲 ${answered<total?`<span style="font-size:.7em;color:var(--ink-2)">（未挑戦 ${total-answered}）</span>`:""}</div>
     <div class="cert-rank rise">${badge} 称号：<b>${title}</b> ${badge}</div>${bdHTML}`;
 return `<div class="content cert">
   <div class="kicker rise">Programme d'Honneur</div>
   <div class="cert-frame rise">
     <div class="cert-title">修 了 証</div><div class="cert-rule"></div>
     <p class="cert-line rise"><span class="cert-recip">${esc(learnerName||"貴方")}</span> 殿<br>
       <b>Linux 歌劇</b> の全幕を踏破し、黒き舞台のアリアを謳い修めしことを証す。</p>
     ${body}
     <div class="cert-date rise">${ymd}　—　L'Opéra du Terminal</div>
     <div class="cert-seal rise">🎭</div>
   </div>
   <div class="cert-actions rise">
     <input id="certName" class="cert-name-in" placeholder="歌い手の名を記す" value="${esc(learnerName)}">
     <div class="cert-btns">
       <button class="cert-dl" id="dlPng">PNGで保存</button>
       <button class="cert-dl" id="dlPdf">PDFで保存</button>
       <button class="cert-dl" id="dlJson">結果を提出</button>
       <button class="cert-reset" id="certReset">記録をリセット</button>
     </div>
   </div>
 </div>
 <div class="prompter"><div class="say">${esc(s.who||"ブラヴォー！見事な公演でした")}</div><div class="who">🎼</div></div>`;
}

/* ---------- sound + bravo ---------- */
let actx;
function chime(good){try{actx=actx||new (window.AudioContext||window.webkitAudioContext)();
 const t=actx.currentTime;const notes=good?[523,659,784,1047]:[294,233];
 notes.forEach((f,i)=>{const o=actx.createOscillator(),g=actx.createGain();o.type=good?"sine":"triangle";o.frequency.value=f;
  o.connect(g);g.connect(actx.destination);const st=t+i*0.08;g.gain.setValueAtTime(0.0001,st);
  g.gain.exponentialRampToValueAtTime(0.16,st+0.02);g.gain.exponentialRampToValueAtTime(0.0001,st+0.34);
  o.start(st);o.stop(st+0.36);});}catch(e){}}
function bravoBurst(scope){const E=["🌹","✦","♪","✧","𝄞"];for(let i=0;i<14;i++){const s=document.createElement('div');
 s.className='bravo';s.textContent=E[i%E.length];s.style.left=(15+Math.random()*70)+"%";s.style.top=(40+Math.random()*30)+"%";
 s.style.animationDelay=(Math.random()*0.25)+"s";scope.appendChild(s);setTimeout(()=>s.remove(),1300);}}

/* ---------- nav / render ---------- */
const bill=$("#bill"),seatsWrap=$("#seats"),stageWrap=$("#stageWrap");
function buildSeats(){seatsWrap.innerHTML="";deck.forEach((_,i)=>{const t=document.createElement('div');t.className='seat'+(i===idx?' on':'');t.onclick=()=>go(i);seatsWrap.appendChild(t);});}
function paint(){bill.innerHTML=billHTML(deck[idx]);
 if(deck[idx].type==="quiz")wireQuiz(bill,deck[idx]);
 if(deck[idx].type==="certificate")wireCert(bill);
 if(STUDENT_MODE)saveProgress();
 $("#prev").disabled=idx===0;$("#next").disabled=idx===deck.length-1;
 [...seatsWrap.children].forEach((t,i)=>t.classList.toggle('on',i===idx));}
function go(n){if(n<0||n>=deck.length||n===idx)return;bill.classList.add('leaving');
 setTimeout(()=>{idx=n;paint();bill.classList.remove('leaving');},380);}
$("#prev").onclick=()=>go(idx-1);$("#next").onclick=()=>go(idx+1);
document.addEventListener('keydown',e=>{const tag=(e.target.tagName||"").toLowerCase();if(tag==="input")return;
 if(['ArrowRight','PageDown',' '].includes(e.key))go(idx+1);
 if(['ArrowLeft','PageUp'].includes(e.key))go(idx-1);
 if(e.key==='Home')go(0);if(e.key==='End')go(deck.length-1);});
stageWrap.addEventListener('click',e=>{if(e.target.closest('.nav')||e.target.closest('.choice')||e.target.closest('.cert-actions'))return;
 go(e.clientX<innerWidth*0.34?idx-1:idx+1);});

function wireQuiz(scope,s){const v=scope.querySelector('[data-verdict]');const btns=[...scope.querySelectorAll('.choice')];
 btns.forEach(b=>b.onclick=ev=>{ev.stopPropagation();const i=+b.dataset.i;
  const firstTry=!(s.qid in results);if(firstTry)results[s.qid]=(i===s.answer);
  attempts[s.qid]=(attempts[s.qid]||0)+1;if(STUDENT_MODE)saveProgress();
  if(i===s.answer){btns.forEach(x=>{x.disabled=true;if(+x.dataset.i===s.answer)x.classList.add('ok');});
    v.innerHTML="ブラヴォー！"+(s.explain?`<span class="ex">${esc(s.explain)}</span>`:"");bravoBurst(scope);chime(true);}
  else{b.classList.add('ng');b.disabled=true;v.textContent="もう一度、舞台の上から。";chime(false);}});}
function wireCert(scope){const reset=scope.querySelector('#certReset'),nameIn=scope.querySelector('#certName'),png=scope.querySelector('#dlPng'),pdf=scope.querySelector('#dlPdf'),json=scope.querySelector('#dlJson');
 if(nameIn){nameIn.onclick=e=>e.stopPropagation();nameIn.oninput=()=>{learnerName=nameIn.value;const rc=scope.querySelector('.cert-recip');if(rc)rc.textContent=learnerName||"貴方";};}
 if(reset)reset.onclick=ev=>{ev.stopPropagation();results={};attempts={};startedAt=Date.now();if(STUDENT_MODE)clearProgress();chime(true);go(0);};
 if(png)png.onclick=ev=>{ev.stopPropagation();exportCert("png");};
 if(pdf)pdf.onclick=ev=>{ev.stopPropagation();exportCert("pdf");};
 if(json)json.onclick=ev=>{ev.stopPropagation();exportResultsJSON();};}

